-btns d-flex align-items-center flex-wrap flex-sm-nowrap mt-40\">\r\n                <input type=\"submit\" class=\"btn btn-primary\" name=\"user_registration_submit\" value=\"Sign up\" \/>\r\n                <input type=\"hidden\" name=\"registration_process\" value=\"true\">\r\n            <\/div>\r\n            <p class=\"text-xl-center mt-4\">If you have already registered <a href=\"#\">Sign in<\/a><\/p>        <\/form>\r\n    <\/div>\r\n\r\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/div>\n\t\t\t\t<div class=\"elementor-column elementor-col-50 elementor-inner-column elementor-element elementor-element-f175135\" data-id=\"f175135\" data-element_type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-a6d030f elementor-widget elementor-widget-image\" data-id=\"a6d030f\" data-element_type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img fetchpriority=\"high\" decoding=\"async\" width=\"606\" height=\"535\" src=\"https:\/\/autohive-wp.themetags.com\/wp-content\/uploads\/2023\/08\/hostim-login-img-1.png\" class=\"attachment-full size-full wp-image-3304\" alt=\"\" srcset=\"https:\/\/autohive-wp.themetags.com\/wp-content\/uploads\/2023\/08\/hostim-login-img-1.png 606w, https:\/\/autohive-wp.themetags.com\/wp-content\/uploads\/2023\/08\/hostim-login-img-1-300x265.png 300w, https:\/\/autohive-wp.themetags.com\/wp-content\/uploads\/2023\/08\/hostim-login-img-1-135x120.png 135w, https:\/\/autohive-wp.themetags.com\/wp-content\/uploads\/2023\/08\/hostim-login-img-1-112x100.png 112w\" sizes=\"(max-width: 606px) 100vw, 606px\" \/>\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/section>\n\t\t\t\t\t<\/div>\n\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/section>\n\t\t\t\t<\/div>\n\t\t","protected":false},"excerpt":{"rendered":